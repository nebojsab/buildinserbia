# Base URL for affiliate product category links (no trailing slash).
# Each category becomes `${VITE_AFFILIATE_BASE_URL}/${slug}` e.g. .../insulation
VITE_AFFILIATE_BASE_URL=https://example.com/affiliate

# Optional: canonical site URL for meta / sharing when you add SEO later
# VITE_SITE_URL=https://kucaplan.rs

# NOTE:
# Admin (Next.js app in ./admin) uses its own env file:
# - ./admin/.env.local (local)
# - ./admin/.env.example (template)

# Optional: LLM intake endpoint (Vercel function at /api/planner-intake)
# Used by server-side extraction in api/planner-intake.ts
# AI Gateway key or compatible gateway bearer token.
# AI_GATEWAY_API_KEY=
# Optional override if your gateway endpoint differs:
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/chat/completions
# Optional model override:
# PLANNER_INTAKE_MODEL=openai/gpt-5.4-mini

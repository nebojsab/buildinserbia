# Base URL for affiliate product category links (no trailing slash).
# Each category becomes `${VITE_AFFILIATE_BASE_URL}/${slug}` e.g. .../insulation
VITE_AFFILIATE_BASE_URL=https://example.com/affiliate

# Optional: canonical site URL for meta / sharing when you add SEO later
# VITE_SITE_URL=https://kucaplan.rs
